<div class="nested-form-wrapper" data-new-record="<%= f.object.new_record? %>">
  <%= render InputComponent.new(name: 'text', form: f, type: :text) %>

    <button type="button" class="btn btn-danger" data-action="nested-form#remove">
      <i class="bi bi-trash"></i>
    </button>

  <%= f.hidden_field :_destroy %>
</div>
